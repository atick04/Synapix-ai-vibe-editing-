{
  "id": "tutorial",
  "name": "Tutorial (Minimal & Expensive)",
  "description": "Эстетичный обучающий стиль: структурированный контент, чистая типографика, мягкие звуковые переходы и плавные зумы для лучшего восприятия.",
  "preview_url": "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=600&auto=format&fit=crop",
  "subtitles": {
    "font_management": {
      "base_sans_font": "Inter-Medium.ttf",
      "accent_serif_font": "CormorantGaramond-Italic.ttf",
      "font_size_px": 52,
      "line_height": 1.4,
      "position_y_percent": 75
    },
    "color_palette": {
      "text_main": "#F5F5F7",
      "text_muted": "#A1A1A6",
      "text_accent": "#0071E3",
      "use_bg_inversion_on_peak": true
    },
    "animation": {
      "type": "word_by_word_fly",
      "duration_frames": 8,
      "easing_curve": "cubic-bezier(0.25, 1, 0.5, 1)"
    },
    "layout": {
      "max_words_per_screen": 3,
      "text_case": "Sentence_Case",
      "use_shadow": true,
      "shadow_blur_px": 10,
      "shadow_opacity": 0.12
    }
  },
  "video_processing": {
    "audio_cut_parameters": {
      "silence_threshold_db": -34.0,
      "min_silence_duration_sec": 0.3,
      "crossfade_duration_ms": 50
    },
    "smart_zoom": {
      "trigger_on_emotional_peak": true,
      "zoom_scale_factor": 1.06,
      "animation_speed_frames": 14
    },
    "broll_matching": {
      "clip_aesthetic_score_threshold": 6.0,
      "min_broll_duration_sec": 2.5,
      "max_broll_duration_sec": 5.0
    }
  },
  "sound_design": {
    "background_music": {
      "genre_tags": [
        "tech-explainers",
        "clean-beats",
        "smart-lofi"
      ],
      "target_bpm": 98,
      "ducking_volume_db": -14
    },
    "sfx_trigger_map": [
      {
        "event": "video_hard_cut",
        "sfx_file": "premium_whoosh_soft.wav",
        "volume_scale": 0.5
      },
      {
        "event": "accent_word_popup",
        "sfx_file": "digital_click_clean.wav",
        "volume_scale": 0.3
      },
      {
        "event": "screen_slide",
        "sfx_file": "smooth_ui_swipe.wav",
        "volume_scale": 0.4
      }
    ]
  }
}
