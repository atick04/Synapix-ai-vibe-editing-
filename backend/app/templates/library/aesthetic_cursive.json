{
  "id": "aesthetic_cursive",
  "name": "Aesthetic Cursive (Эстетичный курсив)",
  "description": "Трендовый стиль Reels: сочетание элегантного рукописного шрифта Marck Script для акцентных слов и строгого Inter Bold. Выглядит стильно и премиально.",
  "preview_url": "https://images.unsplash.com/photo-1516979187457-637abb4f9353?q=80&w=600&auto=format&fit=crop",
  "subtitles": {
    "font_management": {
      "base_sans_font": "Inter_24pt-Bold.ttf",
      "accent_serif_font": "MarckScript-Regular.ttf",
      "font_size_px": 80,
      "line_height": 1.4,
      "position_y_percent": 75
    },
    "color_palette": {
      "text_main": "#F5F5F7",
      "text_muted": "#A1A1A6",
      "text_accent": "#FFFFFF",
      "use_bg_inversion_on_peak": false
    },
    "animation": {
      "type": "pop",
      "duration_frames": 10,
      "easing_curve": "cubic-bezier(0.25, 1, 0.5, 1)"
    },
    "layout": {
      "max_words_per_screen": 3,
      "text_case": "Sentence_Case",
      "use_shadow": true,
      "shadow_blur_px": 20,
      "shadow_opacity": 0.2
    }
  },
  "video_processing": {
    "audio_cut_parameters": {
      "silence_threshold_db": -32.0,
      "min_silence_duration_sec": 0.25,
      "crossfade_duration_ms": 50
    },
    "smart_zoom": {
      "trigger_on_emotional_peak": true,
      "zoom_scale_factor": 1.08,
      "animation_speed_frames": 12
    },
    "broll_matching": {
      "clip_aesthetic_score_threshold": 6.5,
      "min_broll_duration_sec": 2.0,
      "max_broll_duration_sec": 4.5
    }
  },
  "sound_design": {
    "background_music": {
      "genre_tags": [
        "cozy lofi",
        "chill beats",
        "inspirational"
      ],
      "target_bpm": 90,
      "ducking_volume_db": -12
    },
    "sfx_trigger_map": [
      {
        "event": "video_hard_cut",
        "sfx_file": "premium_whoosh_soft.wav",
        "volume_scale": 0.6
      },
      {
        "event": "accent_word_popup",
        "sfx_file": "digital_click_clean.wav",
        "volume_scale": 0.4
      },
      {
        "event": "bento_grid_appear",
        "sfx_file": "smooth_ui_swipe.wav",
        "volume_scale": 0.5
      }
    ]
  }
}
