# API Keys for Synapix AI studio
GOOGLE_API_KEY=your_google_gemini_api_key
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
PEXELS_API_KEY=your_pexels_api_key

# Custom Models (used if OPENROUTER_API_KEY is active)
# DIRECTOR_MODEL=meta-llama/llama-3.3-70b-instruct
# GRAPHICS_MODEL=google/gemini-2.5-flash-lite

# Custom separate AI model for the Graphics/Layout Agent (e.g. llama-3.1-8b-instant)
GRAPHICS_MODEL=llama-3.1-8b-instant

# VLM Local Model (optional, remove if not using local LM Studio)
VLM_BASE_URL=http://localhost:1234/v1
VLM_MODEL=qwen3-vl-8b

# Cloudflare R2 Storage (for production video storage)
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET_NAME=synapix-videos
# R2_PUBLIC_URL=https://pub-xxx.r2.dev
